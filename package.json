{
  "name": "micro-claw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "micro-claw": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "bootstrap": "tsx src/cli.ts bootstrap --allow-direct",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "telegram:start": "tsx src/cli.ts telegram-start",
    "ollama:setup": "tsx src/cli.ts ollama-setup",
    "one-click": "node ./scripts/micro-claw-one-click.mjs",
    "local:ollama": "NODE_OPTIONS= node ./scripts/run-local-llm.mjs --provider ollama",
    "local:llamacpp": "NODE_OPTIONS= node ./scripts/run-local-llm.mjs --provider llamacpp",
    "hyperagents:package": "NODE_OPTIONS= node ./scripts/hyperagents-local-package.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
